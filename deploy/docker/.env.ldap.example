##############################################################
# SigNoz LDAP Configuration
# Copy this file to .env.ldap and edit values for your environment
##############################################################

COMPOSE_PROJECT_NAME=signoz

# SigNoz Admin (auto-created on first startup)
SIGNOZ_ADMIN_EMAIL=admin@setyazilim.com
SIGNOZ_ADMIN_PASSWORD=SetAdmin2024!@
SIGNOZ_ORG_NAME=SETYazilim
SIGNOZ_JWT_SECRET=change-me-in-production

# LDAP / Active Directory Settings
LDAP_HOST=172.16.1.172
LDAP_PORT=389
LDAP_USE_TLS=false
LDAP_INSECURE_SKIP_VERIFY=false

# AD domain names for bind (comma-separated, each in quotes)
# Users authenticate as DOMAIN\username
LDAP_AD_DOMAINS="SETYAZILIM","SETSOFTWARE"

# Email domain that triggers LDAP authentication
# Users with @setyazilim.com emails will be authenticated via LDAP
LDAP_EMAIL_DOMAIN=setyazilim.com

# Optional: Base DN for user search (leave empty for bind-only auth)
LDAP_BASE_DN=

# Optional: User search filter (default: sAMAccountName=%s)
LDAP_USER_SEARCH_FILTER=

# Optional: LDAP attribute for email (default: mail)
LDAP_EMAIL_ATTRIBUTE=

# Optional: LDAP attribute for display name (default: displayName)
LDAP_NAME_ATTRIBUTE=
